<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name=”viewport” content="width =device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <title>@ViewBag.Title - DH-English</title>
    <link href="~/Assets/kendo/styles/kendo.mobile.all.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.common.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.rtl.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.bootstrap.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/kendo.ext.css" rel="stylesheet" />
    <link href="~/Assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="~/Areas/FiveStar/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Areas/FiveStar/Content/Site.css" rel="stylesheet" />
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Areas/FiveStar/Scripts/moment.js"></script>
    <link href="~/styles/layout.css" rel="stylesheet" />
    @Scripts.Render("~/bundles/vendor")
    @RenderSection("scripts", required: false)
    <script>
        function isMobile() {
            var result = false;
            var matches = [
                /(Windows Phone(?: OS)?)\s(\d+)\.(\d+(\.\d+)?)/,
                /(Silk)\/(\d+)\.(\d+(\.\d+)?)/,
                /(Android|Android.*(?:Opera|Firefox).*?\/)\s*(\d+)\.?(\d+(\.\d+)?)?/,
                /(iPhone|iPod).*OS\s+(\d+)[\._]([\d\._]+)/,
                /(iPad).*OS\s+(\d+)[\._]([\d_]+)/,
                /(MeeGo).+NokiaBrowser\/(\d+)\.([\d\._]+)/,
                /(webOS)\/(\d+)\.(\d+(\.\d+)?)/,
                /(BlackBerry|BB10).*?Version\/(\d+)\.(\d+(\.\d+)?)/,
                /(PlayBook).*?Tablet\s*OS\s*(\d+)\.(\d+(\.\d+)?)/,
                /(MSIE)\s+(\d+)\.(\d+(\.\d+)?)/,
                /(tizen).*?Version\/(\d+)\.(\d+(\.\d+)?)/i,
                /(sailfish).*rv:(\d+)\.(\d+(\.\d+)?).*firefox/i,
                /(Mobile).*rv:(\d+)\.(\d+(\.\d+)?).*Firefox/
            ];

            for (var i = 0; i < matches.length; i++) {
                result = matches[i].test(window.navigator.userAgent);
                if (result) {
                    break;
                }
            }

            return result;
        }

        $(document).ready(function () {
            var app = new kendo.mobile.Application(document.body, {
                platform: "ios7"
            });

        })
    </script>
</head>
@using QLDH.DataAccess.Models
@{
    TaiKhoanModel userinfor = (TaiKhoanModel)Session["UserInfor"];
}
<body>
    <div id="home" data-role="view" data-layout="default">
        @RenderBody()
    </div>
    <div data-role="layout" data-id="default">
        <header data-role="header">
            <div data-role="navbar" id="normal" class="km-accent">
                <a data-align="left" data-role="button" href="#about" data-rel="drawer" data-icon="drawer-icon"></a>
                <span data-role="view-title"></span>
                <span class="km-view-subtitle">
                    <img src="~/Images/fslogo.png" style="width:200px" />
                </span>
                <a data-align="right" data-role="button" data-click="showSearch" data-click-on="down" data-icon="search"></a>
            </div>
            <div data-role="navbar" id="search" class="navbar-hidden">
                <div data-align="left" id="timer-container">
                    <i class="timer-icon fa fa-3x fa-clock-o"></i>
                    <span class="timer"> @DateTime.Now.ToString("dd/MM/yyyy")</span>
                </div>
                <div data-align="right" id="demos-search-container">
                    <span class="student-name">@userinfor.lstHocSinh[0].TenHocSinh</span>
                    <img src="~/Images/schoolbus.jpg" class="k-avatar" />
                </div>
            </div>
        </header>

        <!--View content will render here-->
        <footer data-role="footer">
            <div data-role="tabstrip">
                <a data-icon="home" href="/FiveStar/FSHome">Home</a>
            </div>
        </footer>
    </div>

    <div data-role="drawer" class="left-nav" data-stretch="true" id="about" data-before-show="disableInSourceCode">
        <div data-role="header">
            <div data-role="navbar" style="background-color: #ffa7a7;">
                MENU
            </div>
        </div>

        <ul data-role="listview" id="external-resources">
            <li>
                <a data-rel="external" href="/Home/Index">
                    <img src="~/Images/icons/home-icon.png" /> Home
                </a>
            </li>
            <li>
                <a data-rel="external" href="/Class/Index">
                    <img src="~/Images/icons/class-icon.png" /> Class
                </a>
            </li>
            <li>
                <a data-rel="external" href="/Library/Index">

                    <img src="~/Images/icons/library-icon.png" /> Library
                </a>
            </li>
            <li>
                <a data-rel="external" href="/Favorite/Index">

                    <img src="~/Images/icons/favorite.png" /> Favorite
                </a>
            </li>
        </ul>

        <div data-role="footer" id="left-nav-footer">
            <ul data-role="listview">
                <li>
                    <a data-rel="external" href="/About/Terms">

                        <img src="~/Images/icons/termofuse-icon.png" /> Terms of Use
                    </a>
                </li>
                <li>
                    <a data-rel="external" href="/About/Infomation">

                        <img src="~/Images/icons/infomation-icon.png" /> Product Infomation
                    </a>
                </li>
                <li>
                    <a data-rel="external" href="/About/Contact">

                        <img src="~/Images/icons/contactus-icon.png" /> Contact Us
                    </a>
                </li>
            </ul>
        </div>
    </div>
    <div id="dialogRoot"></div>

</body>
</html>
