        }
        function timkiem() {
            $("#result").show();
        }

        function parseExcel(file) {
            var reader = new FileReader();

            reader.onload = function (e) {
                var data = e.target.result;
                var workbook = XLSX.read(data, {
                    type: 'binary'
                });

                workbook.SheetNames.forEach(function (sheetName) {
                    // Here is your object
                    var XL_row_object = XLSX.utils.sheet_to_row_object_array(workbook.Sheets[sheetName]);
                    var json_object = JSON.stringify(XL_row_object);

                    jsondata = JSON.parse(json_object);
                    $.each(jsondata, function (index, item) {
                        item.TienThuKhach = Number(item.TienThuKhach);
                        item.CuocXe = Number(item.CuocXe);
                        item.SoLuong = Number(item.SoLuong);
                        item.TraLaiVP = Number(item.TraLaiVP);
                    })

                    lenght = jsondata.length;
                    var dsgrid = new kendo.data.DataSource({
                        data: jsondata,
                        schema: {
                            model: {
                                id: "ID",
                                fields: {
                                    ID: { type: 'number', editable: false },
                                    TenKhachHang: { type: 'text', editablle: true },
                                    NoiNhan: { type: 'text', editablle: true },
                                    DienThoai: { type: 'text', editable: true },
                                    LaiHang: { type: 'text', editable: true },
                                    SoLuong: { type: 'number', editable: true },
                                    TrongLuong: { type: 'text', editable: true },
                                    TienThuKhach: { type: 'number', editablle: true, validation: { min: 0 } },
                                    CuocXe: { type: 'number', editablle: true, validation: { min: 0 } },
                                    TraLaiVP: { type: 'number', editablle: true, validation: { min: 0 } }
                                }
                            }
                        },
                        aggregate: [{ field: "TienThuKhach", aggregate: "sum" },
                        { field: "CuocXe", aggregate: "sum" },
                        { field: "TraLaiVP", aggregate: "sum" }],
                        pageSize: 100
                    });
                    $("#grid").data("kendoGrid").setDataSource(dsgrid);
                    kendo.ui.progress($("body"), false);
                    notification.show({ kValue: "Tải dữ liệu thành công" }, "success");
                })

            };

            reader.onerror = function (ex) {
                console.log(ex);
            };



            reader.readAsBinaryString(file);

        };
