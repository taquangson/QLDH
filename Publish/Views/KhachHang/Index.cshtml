@{
    ViewBag.Title = "Danh mục khách hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Assets/stringeeConfig.js"></script>
<div id="dialogRoot"></div>
<div class="row">
    <h2><b>Danh sách khách hàng</b></h2>
</div>
<div class="row toolBarMenu">
    <button class="k-button bg-blue" onclick="ThemMoi()"><i class="fa fa-plus-square"></i>Thêm</button>
    <button class="k-button bg-orange" onclick="openEditWindow()"><i class="fa fa-wrench"></i>Sửa</button>
    <button class="k-button bg-red" onclick="Xoa()"><i class="fa fa-close"></i>Xóa</button>
    <button class="k-button bg-green" onclick="XuatExcel()"><i class="fa fa-file-excel-o"></i>Xuất Excel</button>
</div>
<div class="row">
    <div id="grid"></div>
</div>
<div style="visibility:hidden" id="window">
    <div class="toolBarMenu">
        <button class="k-button bg-blue" onclick="Luu()"> <i class="fa fa-plus-square"> Lưu </i></button>
        <button class="k-button bg-red" onclick="Huy()"> <i class="fa fa-close"> Hủy</i> </button>
    </div>
    <form id="formChiTiet">
        <div class="form-group">
            <input id="ID" type="hidden" />
        </div>
        <div class="form-group valid" toggle-valid="Ten">
            <label style="width:100%">Tên: <span style="color:red">*</span></label>
            <input id="Ten" placeholder="Tên" type="text" class="k-textbox input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="DiaChi">
            <label style="width:100%">Địa Chỉ: <span style="color:red">*</span></label>
            <input id="DiaChi" placeholder="Địa Chỉ" type="text" class="k-textbox input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="SoDienThoai">
            <label style="width:100%">Số Điện Thoại: <span style="color:red">*</span></label>
            <input id="SoDienThoai" placeholder="Số Điện Thoại" type="text" class="k-textbox input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="TrangThai">
            <label style="width:100%">Trạng Thái:</label>
            <select id="TrangThai" class="k-textbox input" style="height:27px">
                <option value="1">Hoạt động</option>
                <option value="0">Không hoạt động</option>
            </select>
        </div>
        <div class="form-group valid" toggle-valid="Email">
            <label style="width:100%">Email: <span style="color:red">*</span></label>
            <input id="Email" placeholder="Email" type="text" class="k-textbox input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="GhiChu">
            <label style="width:100%">Ghi Chú: <span style="color:red">*</span></label>
            <input id="GhiChu" placeholder="Ghi Chú" type="text" class="k-textbox input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group">
            <input id="MatKhau" type="hidden" />
        </div>
    </form>
</div>
<script src="~/Scripts/js/khachhang.js"></script>