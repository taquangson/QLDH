@{
    ViewBag.Title = "Quản lý công thức học phí";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="dialogRoot"></div>
<div class="row">
    <h2><b>Danh sách công thức thu học phí</b></h2>
</div>
<div class="row toolBarMenu">
    <button class="k-button bg-blue" onclick="ThemMoi()"> <i class="fa fa-plus-square"> Thêm </i></button>
    <button class="k-button bg-orange" onclick="Sua()"> <i class="fa fa-wrench"> Sửa</i> </button>
    <button class="k-button bg-red" onclick="Xoa()"> <i class="fa fa-close"> Xóa</i> </button>
</div>
<div class="row">
    <div id="grid"></div>
</div>

<div style="visibility:hidden" id="window">
    <div class="toolBarMenu">
        <button class="k-button bg-blue" onclick="Luu()"> <i class="fa fa-plus-square"> Lưu </i></button>
        <button class="k-button bg-red" onclick="Huy()"> <i class="fa fa-close"> Hủy</i> </button>
    </div>
    <form id="formChiTiet">
        <div class="form-group">
            <input id="ID" type="hidden" />
        </div>
        <div class="form-group valid" toggle-valid="TenCongThuc">
            <label style="width:100%">Tên: <span style="color:red">*</span></label>
            <input id="TenCongThuc" type="text" class="k-textbox input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="DonVi">
            <label style="width:100%">Đơn vị nhỏ nhất:</label>
            <input id="DonVi" class="input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="HocPhi">
            <label style="width:100%">Học phí:</label>
            <input id="HocPhi" class="input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="Block">
            <label style="width:100%">Tính theo block:</label>
            <input id="Block" class="input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="LichThanhToan">
            <label style="width:100%">Lịch thanh toán:</label>
            <input id="LichThanhToan" class="input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group" toggle-valid="MoTa">
            <label style="width:100%">Mô Tả: </label>
            <textarea id="MoTa" class="k-textbox" style="width: 100%; height: 150px;"></textarea>
        </div>
    </form>
</div>
<script src="~/Scripts/js/congthuctinhhocphi.js"></script>
