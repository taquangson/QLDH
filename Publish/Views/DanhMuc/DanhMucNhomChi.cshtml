@{
    ViewBag.Title = "Quản lý nhóm chi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .image-preview {
        width: 100px;
        height: 100px;
        object-fit: contain;
    }

    .k-dropdown-wrap.k-state-default, .k-multiselect-wrap {
        border-color: #929090;
    }
</style>
<div id="dialogRoot"></div>
<div class="row">
    <h2><b>Danh sách nhóm chi</b></h2>
</div>
<div class="row toolBarMenu">
    <button class="k-button bg-blue" onclick="ThemMoi()"> <i class="fa fa-plus-square"> Thêm </i></button>
    <button class="k-button bg-orange" onclick="Sua()"> <i class="fa fa-wrench"> Sửa</i> </button>
    <button class="k-button bg-red" onclick="Xoa()"> <i class="fa fa-close"> Xóa</i> </button>
    <button class="k-button bg-green" onclick="XuatExcel()"> <i class="fa fa-file-excel-o"> Xuất excel</i> </button>
</div>
<div class="row">
    <div id="grid"></div>
</div>

<div style="visibility:hidden" id="window">
    <div class="toolBarMenu">
        <button class="k-button bg-blue" onclick="Luu()"> <i class="fa fa-plus-square"> Lưu </i></button>
        <button class="k-button bg-red" onclick="Huy()"> <i class="fa fa-close"> Hủy</i> </button>
    </div>
    <form id="formChiTiet">
        <div class="form-group">
            <input id="ID" type="hidden" />
        </div>
        <div class="form-group valid" toggle-valid="TenNhomChi">
            <label style="width:100%">Tên Nhóm Chi: <span style="color:red">*</span></label>
            <input id="TenNhomChi" placeholder="Tên nhóm chi" type="text" class="k-textbox input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="MaNhomChi">
            <label style="width:100%">Mã Nhóm Chi:</label>
            <input id="MaNhomChi" placeholder="Mã nhóm chi" type="text" class="k-textbox input" />
        </div>
        <div class="form-group valid" toggle-valid="TrangThai">
            <label style="width:100%">Trạng Thái:</label>
            <select id="TrangThai" class="input">
                <option value="1">Hoạt động</option>
                <option value="0">Không hoạt động</option>
            </select>
        </div>
        <div class="form-group valid" toggle-valid="NhomChi">
            <label style="width:100%">Nhóm Chi Cha:</label>
            <input id="NhomChi" class="input" />
        </div>
        <div class="form-group" toggle-valid="MoTa">
            <label style="width:100%">Mô Tả: </label>
            <textarea id="MoTa" class="k-textbox" style="width: 100%; height: 310px;"></textarea>
        </div>
    </form>
    
</div>
<script src="~/Scripts/js/danhmucnhomchi.js"></script>