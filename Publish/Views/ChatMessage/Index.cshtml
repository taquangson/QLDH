
@{
    ViewBag.Title = "Quản lý lịch tin nhắn từ phụ huynh";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/js/tinnhanphuhuynh.js"></script>
<div id="dialogRoot"></div>
<div class="row">
    <h2><b>Tin nhắn từ phụ huynh</b></h2>
</div>
<div class="row" style="margin-top:10px;margin-bottom:10px;">
    <div class="col-sm-2">
        <label style="width:100%">Từ ngày</label>
        <input style="width:100%" id="TuNgay" />
    </div>
    <div class="col-sm-2">
        <label style="width:100%">Đến ngày</label>
        <input style="width:100%" id="DenNgay" />
    </div>
    <div class="col-sm-2">
        <label style="width:100%;height:15px;"> </label>
        <button class="k-button bg-blue" onclick="LoadTinNhan()"> <i class="fa fa-search"> Xem tin nhắn </i></button>
    </div>
</div>
<div class="row">
    <div id="gridTinNhan"></div>
</div>
