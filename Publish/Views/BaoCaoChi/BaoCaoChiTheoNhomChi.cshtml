
@{
    ViewBag.Title = "Báo cáo chi theo nhóm chi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/js/baocaochi_js/baocaochitheonhomchi.js"></script>
<div id="rootContainer" style="display:none">
    <div class="row">
        <h2><b>Báo cáo chi theo nhóm chi</b></h2>
    </div>
    <div id="tabstrip">
        <ul>
            <li class="k-state-active">
                Theo khoảng thời gian
            </li>
            <li>
                Theo Năm
            </li>
        </ul>
        <div style="border: none">
            <div class="row" style="margin-top:10px;">
                <div class="col-sm-2">
                    <label style="width:100%">Từ ngày</label>
                    <input style="width:100%" id="TuNgay" />
                </div>
                <div class="col-sm-2">
                    <label style="width:100%">Đến ngày</label>
                    <input style="width:100%" id="DenNgay" />
                </div>
                <div class="col-sm-3">
                    <label style="width:100%"> </label>
                    <button class="k-button bg-blue" onclick="TimKiem()"> <i class="fa fa-search"> Xem báo cáo </i></button>
                    <button class="k-button bg-green" onclick="XuatExcel()"> <i class="fa fa-file-excel-o"> Xuất excel </i></button>
                </div>
            </div>
            <div class="row" style="margin-top:10px; display: flex; margin-left: 10px">
                <div id="gridData" style="flex: 1; "></div>
                <div id="pieChart" style="flex: 2;margin: 20px"></div>

            </div>
        </div>
        <div>
            <div class="row" style="margin-top:10px;">
                <div class="col-sm-2">
                    <label style="width:100%">Năm: </label>
                    <input style="width:100%" id="Nam" />
                </div>
                <div class="col-sm-3">
                    <label style="width:100%"> </label>
                    <button class="k-button bg-blue" onclick="TimKiemNam()"> <i class="fa fa-search"> Xem báo cáo </i></button>
                </div>
            </div>
            <div>
                <div id="barChartStack" style="margin: 20px"></div>
                

            </div>


        </div>
    </div>
        
    </div>
