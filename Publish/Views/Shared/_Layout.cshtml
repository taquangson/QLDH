                        </ul>
                        }


                    </nav>
                </div>
            </div>
            <!-- /top navigation -->
            <!-- page content -->
            <div class="right_col" role="main" style="padding-top:20px;overflow-x:scroll;">
                @RenderBody()
            </div>
            <!-- /page content -->
            <!-- footer content -->
            <footer>
                <div class="pull-left">
                    <p>Website developed by QS - quangson0409@gmail.com</p>
