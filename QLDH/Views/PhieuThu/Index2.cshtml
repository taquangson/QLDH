
@{
    ViewBag.Title = "Bán phiếu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script>document.write('<script src="../Scripts/js/phieuthuv2.js?dev=' + Math.floor(Math.random() * 100) + '"\><\/script>');</script>
<link type="text/javascript" href="https://momentjs.com/downloads/moment.js" />
<style>
    .trang {
        background-color: #fff;
    }

    .do {
        background-color: #fc9595;
    }

    .xanh {
        background-color: #78ff51;
    }

    .k-dialog-buttongroup .k-button {
        width: 50%;
    }
</style>
<div id="rootContainer" style="display:none">
    <div id="dialogRoot"></div>
    <div class="row">
        <h2><b>Quản lý bán phiếu vào lớp</b></h2>
    </div>
    <div class="row">
        <div class="col-sm-3">
            <label style="width:100%">Khối</label>
            <div style="width:100%" id="comboKhoi"></div>
        </div>
        <div class="col-sm-3">
            <label style="width:100%">Lớp</label>
            <div style="width:100%" id="comboLop"></div>
        </div>
        <div class="col-sm-3">
            <label style="width:100%"> </label>
            <button class="k-button bg-blue" onclick="LoadGridDataTimKiemHocSinh()"> <i class="fa fa-search"> Tìm kiếm </i></button>
        </div>
    </div>
    <div class="row">
        <div id="gridTimKiemHocSinh"></div>
    </div>
</div>

<script type="text/x-kendo-template" id="template">
    <div class="orders"></div>
</script>
<script type="text/x-kendo-template" id="template2">
    <div class="orders2"></div>
</script>

<div id="windowLapPhieuThu">
    <div class="toolBarMenu">
        <button class="k-button bg-green" id="btnTaoPhieu" onclick="TaoPhieuThu()"> <i class="fa fa-save">  Lưu phiếu </i></button>
        <button class="k-button bg-green" id="btnThanhToan" onclick="ThanhToan()"> <i class="fa fa-money">  Thanh toán </i></button>
        <button class="k-button bg-green" id="btnGuiThongBao" onclick="InTamTinh()"> <i class="fa fa-send">  Gửi thông báo phí</i></button>
        <button class="k-button bg-green" id="btnGuiThongBaoZNS" onclick="GuiThongBaoZNS()"> <i class="fa fa-send">  Gửi Zalo</i></button>
        <input id="ThoiGianNhanBan" />
        <button class="k-button bg-blue" id="btnNhanBan" onclick="NhanBan()"> <i class="fa fa-clone"> Nhân bản</i></button>
        @*<button class="k-button bg-blue" onclick="ThongBaoHocPhi()"> <i class="fa fa-paper-plane"> Gửi thông báo học phí</i></button>*@
        <button class="k-button bg-red" onclick="HuyPhieuThu()"> <i class="fa fa-close"> Hủy </i> </button>

        @*<div style="float:right">
                <span style="color:#3e835a">Phiếu tạm tính: </span><div style="width:300px;" id="combotamtinh"></div>
            </div>*@
    </div>
    <div style="width:100%">
        <div>
            <input id="ID_HocSinh" type="hidden" />
            <input id="ID_PhieuThu" type="hidden" />
            @*<input id="ID_PhieuTamTinh" type="hidden" />*@
        </div>
        <div style="width:100%;float:left;padding-left:20px;">
            <div style="margin-top:5px">
                <div style="width:15%;float:left;">
                    <label style="width: 100%; line-height: 25px;">Học sinh: <span id="TenHocSinh"></span></label>
                    <label style="width: 100%; line-height: 25px; ">Tổng tiền: <span id="TongTien"></span></label>
                    <label style="width: 100%; line-height: 25px; ">Đã thanh toán: <span id="DaThanhToan"></span></label>
                    <label style="width: 100%; line-height: 30px;">Còn lại: <span id="ConLai"></span></label>
                </div>
                <div style="width:20%;float:left">
                    <label style="width: 40%; line-height: 25px; ">Số tiền thanh toán:</label>
                    <input style="width:50%" id="SoTienThanhToan" />

                    <label style="width: 40%; line-height: 25px; ">Hình thức thanh toán:</label>
                    <input style="width:50%" id="HinhThuc" />

                    <label style="width: 40%; line-height: 25px; ">Ngày lập phiếu:</label>
                    <input style="width:50%" id="NgayLapPhieu" />

                    <label style="width: 40%; line-height: 25px; ">Ngày thanh toán:</label>
                    <input style="width:50%" id="NgayThanhToan" />
                </div>
                <div style="width: 20%; float: left; padding-top: 4px;">
                    <label style="width: 40%; line-height: 25px; ">Phụ thu:</label>
                    <input style="width:50%" id="TienPhuThu" />

                    <label style="width: 40%; line-height: 25px; ">Giảm trừ:</label>
                    <input style="width:50%" id="TienGiamTru" />

                    <div style="width:100%">
                        <input type="checkbox" id="guithongbao" class="k-checkbox" checked="checked" style="margin: 0;">
                        <label class="k-checkbox-label" for="guithongbao">Gửi email khi thanh toán</label>
                    </div>
                  
                </div>
            </div>
        </div>
        <div style="width:53%;float:left;margin-left:2%">
            @*<h4 style="width:100%;text-align:center;text-transform:uppercase">PHIẾU THANH TOÁN</h4>*@

            <div style="margin-top:5px">
                <label style="width:100%">Danh sách phiếu học:</label>
                <div id="gridPhieuMua"></div>
            </div>
            <div style="margin-top:5px">
                <label style="width:100%">Danh sách sản phẩm:</label>
                <div id="gridSanPham"></div>
            </div>
            @*<div style="width:100%;margin-top:5px">
                    <div style="width:50%;float:left">
                        <label style="width:100%">Phụ thu:</label>
                        <div id="gridPhuThu"></div>
                    </div>
                    <div style="width:50%;float:left">
                        <label style="width:100%">Giảm trừ:</label>
                        <div id="gridGiamTru"></div>
                    </div>
                </div>*@
        </div>
        <div style="width:43%;float:left;margin-left:1%">

            <div style="margin-top:5px">
                <label style="width:100%">Thống kê buổi học tháng trước:</label>
                <div id="gridBuoiHocThangTruoc"></div>
            </div>
        </div>
    </div>
</div>
<div id="windowLichSuPhieuThu">
    <div id="gridLichSuPhieuThu"></div>
</div>

<script id="rowTemplate" type="text/x-kendo-tmpl">
    <tr role='row' class='#= SoBuoiHoc == SoBuoiDaMua ? "trang" : SoBuoiHoc < SoBuoiDaMua ? "xanh" : "do"#'>
        <td>
            # if (SoBuoiHoc != SoBuoiDaMua) { #
            <input class='k-checkbox' data-role='checkbox' type='checkbox' id='cb_#:uid#'>
            <label class='k-checkbox-label k-no-text' for='cb_#:uid#'>​</label>
            # }#
        </td>
        <td>
            #= TenLop #
        </td>
        <td class="text-center">
            #= Thang # / #= Nam #
        </td>
        <td class="text-center">
            <span class='tooltip-damua' data-idphieu='#= ID_PhieuHoc #'>#= SoBuoiHoc # / #= SoBuoiDaMua #</span>
        </td>
        <td class="text-center">
            #= SoBuoiTheoLich #
        </td>
         <td class="text-right">
            #= kendo.toString(PhuThu,'n0') #
            </td>
         <td class="text-right">
            #= kendo.toString(GiamTru,'n0') #
        </td>
    </tr>
</script>

<script id="templateTooltip" type="text/x-kendo-template">
    #var idphieu = target.attr("data-idphieu"); #
    #loadLichSuMuaPhieu(idphieu)#
    <div id="contentgrid">
    </div>
</script>