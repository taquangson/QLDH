@{
    Layout = "";
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>MẦM NON THỰC NGHIỆM JUDO PRESCHOOL - Thông báo học phí</title>
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            margin: 0 20px;
        }

        tbody td {
            font-size: 12px;
        }
    </style>
</head>
<body>
    <div class="row" style="background-color: #355593;color: #fff;padding: 0px 5px;">
        <h4 class="text-center"><b style="text-transform:uppercase;font-size:13px;">MẦM NON THỰC NGHIỆM JUDO PRESCHOOL</b></h4>
        <h5 class="text-center">@Model.TaiKhoan.DiaChiChiNhanh</h5>
        <h5 class="text-center">@Model.TaiKhoan.DienThoaiChiNhanh</h5>
        <p class="text-center" style="border-bottom:dashed 1px"></p>
        <h4 class="text-center" style="margin-top:20px;margin-bottom:20px;"><b>PHIẾU XÁC NHẬN THANH TOÁN HỌC PHÍ</b></h4>
        <p style="font-size:12px;width:50%;float:left">Ngày lập: @Model.PhieuThu.NgayTao.ToString("dd/MM/yyyy HH:mm")</p>
        <p style="font-size:12px;width:50%;float:left;text-align:left">Người lập: @Model.PhieuThu.NguoiLap</p>
        <p style="font-size:12px;width:100%;float:left;text-align:left">Học sinh: <b>@Model.PhieuThu.TenHocSinh</b></p>
        @if (!string.IsNullOrWhiteSpace(Model.HocSinh.GhiChu))
        {
            <p style="font-size:10px;width:100%;float:left;text-align:left">
                @Model.HocSinh.GhiChu
            </p>
        }

        <b style="margin-top:20px;display:block">Đơn chính</b>
        <table style="margin:2px;width:100%" border="1">
            <thead>
                <tr style="border-bottom:solid 1px;">
                    @*<td style="width:10%;text-align:center">STT</td>*@
                    <td style="width:40%;text-align:center">Lớp</td>
                    <td style="width:20%;text-align:center">Tháng</td>
                    <td style="width:20%;text-align:center">Số buổi</td>
                    <td style="width:20%;text-align:center">Thành tiền</td>
                </tr>
            </thead>
            <tbody style="border-bottom: solid 1px;">
                @{int i = 0; }
                @foreach (QLDH.DataAccess.Models.PhieuHocModel ph in Model.PhieuThu.lstPhieuHoc)
                {
                    i++;
                    <tr>
                        @*<td style="text-align:center">@i</td>*@
                        <td style="text-align:left">@ph.TenLop</td>
                        <td style="text-align:center">Tháng @ph.Thang </td>
                        <td style="text-align:center">@ph.SoBuoi buổi</td>
                        <td style="text-align:right;">@ph.SoTien.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>



        <b style="margin-top:20px;display:block">Phụ thu</b>
        <table style="margin:2px;width:100%" border="1">
            <thead>
                <tr style="border-bottom:solid 1px;">
                    @*<td style="width:10%;text-align:center">STT</td>*@
                    @*<td style="width:60%;text-align:center">Nội dung</td>
        <td style="width:30%;text-align:center">Thành tiền</td>*@
                    <td style="width:40%;text-align:center">Dịch vụ/Sản phẩm</td>
                    <td style="width:20%;text-align:center">Tháng</td>
                    <td style="width:20%;text-align:center">Số lượng</td>
                    <td style="width:20%;text-align:center">Ghi chú</td>
                    <td style="width:20%;text-align:center">Thành tiền</td>

                </tr>
            </thead>
            <tbody style="border-bottom: solid 1px;">
                @{int j = 0; }
                @foreach (QLDH.DataAccess.Models.PhuThuGiamTruModel pt in Model.PhieuThu.lstPhuThu)
                {
                    j++;
                    <tr>
                        @*<td style="text-align:center">@i</td>*@
                        <td style="text-align:left">@pt.TenLop</td>
                        <td style="text-align:center">Tháng @pt.Thang </td>
                        <td style="text-align:center">@pt.SoBuoi</td>
                        <td style="text-align:right;">@pt.LyDo</td>
                        <td style="text-align:right;">@pt.DonGia.ToString("N0")</td>

                    </tr>
                }
            </tbody>
        </table>



        <b style="margin-top:20px;display:block">Giảm trừ</b>
        <table style="margin:2px;width:100%" border="1">
            <thead>
                <tr style="border-bottom:solid 1px;">
                    @*<td style="width:10%;text-align:center">STT</td>*@
                    @*<td style="width:60%;text-align:center">Nội dung</td>
        <td style="width:30%;text-align:center">Thành tiền</td>*@
                    <td style="width:40%;text-align:center">Dịch vụ/Sản phẩm</td>
                    <td style="width:20%;text-align:center">Tháng</td>
                    <td style="width:20%;text-align:center">Số lượng</td>
                    <td style="width:20%;text-align:center">Ghi chú</td>
                    <td style="width:20%;text-align:center">Thành tiền</td>

                </tr>
            </thead>
            <tbody style="border-bottom: solid 1px;">
                @{int k = 0; }
                @foreach (QLDH.DataAccess.Models.PhuThuGiamTruModel pt in Model.PhieuThu.lstGiamTru)
                {
                    k++;
                    <tr>
                        @*<td style="text-align:center">@k</td>*@
                        <td style="text-align:left">@pt.TenLop</td>
                        <td style="text-align:center">Tháng @pt.Thang </td>
                        <td style="text-align:center">@pt.SoBuoi</td>
                        <td style="text-align:right;">@pt.LyDo</td>
                        <td style="text-align:right;">@pt.DonGia.ToString("N0")</td>

                    </tr>
                }
            </tbody>
        </table>
        <p class="text-right"><b>Tổng:  @Model.PhieuThu.TongThu.ToString("N0") VNĐ</b></p>
        @if (Model.PhieuThu.DaThanhToan > 0)
        {
            <p class="text-right"><b>Đã thanh toán:  @Model.PhieuThu.DaThanhToan.ToString("N0") VNĐ</b></p>
        }
        @if (Model.TaiKhoan.ID_ChiNhanh == 1)
        {
            <p class="text-center" style="border-top:dashed 1px; font-size:12px;vertical-align:middle;padding-top:10px;">

            </p>

        }
        <span style="font-size:11px;vertical-align:top">
            Thông báo sẽ được gửi SMS tới ĐTDĐ của phụ huynh hoặc qua email đăng ký vào đầu tháng. (Phụ huynh vui lòng liên hệ phòng kế toán của trường nếu như đến mùng 5 chưa nhận được thông báo học phí)
            <br />
            <span style="color:red">
                Thời gian nộp học phí và các khoản phụ phí: Từ ngày 3-10 hàng tháng.
            </span>
            <br />

            Thông tin số tài khoản của nhà trường:
            <br />

            - Chủ tài khoản: Lê Tuấn Anh
            <br />

            - STK: 230109508
            <br />

            - Ngân hàng CPTM Việt Nam Thịnh Vượng (VPBank)
            <br />

            Nội dung: DHP_[Tên học sinh]_[Tên lớp]
            <br />
            <span style="color:red">"Xin lưu ý: Trường mầm non thực nghiệm Judo chỉ sử dụng duy nhất TK này để thực hiện thu các khoản phí nộp của phụ huynh. Trường hợp PH nộp tiền vào TK nào khác TK trên, nhà trường sẽ không chịu trách nhiệm".</span>
            <br />
            Chính sách ưu đãi khi nộp phí sớm:
            <br />

            Đóng HP 3 tháng Giảm 3%
            <br />

            Đóng HP 6 tháng Giảm 5%
            <br />

            Đóng HP 12 tháng Giảm 7%
            <br />

            Gia đình có từ 02 con học tại Trường Miễn phí nhập học + giảm 10% học phí cho bé sau trong thời gian 02 bé học.
            <br />

            Xin lưu ý việc giảm trừ học phí khi các con phát sinh nghỉ theo nhu cầu hoặc ốm đau như sau:
            <br />

            1, Các con nghỉ theo nhu cầu để được giảm trừ tiền ăn xin Gia đình thông báo vào trước 15h của ngày hôm trước
            <br />

            2, Các con vì lý do ốm đau đột xuất xin Gia đình thông báo trước 6h hằng ngày để Nhà trường giảm trừ tiền phí ăn cho các con.
            <br />

            (Khi phụ huynh thực hiện chuyển khoản xong xin vui lòng gửi lại hình ảnh chuyển khoản qua Email này và Không gửi biên lai lên nhóm lớp trên Zalo)
            <br />

            Quá hạn từ 5 ngày kể từ ngày đến hạn (với phụ huynh không xin phép chậm nộp) hoặc quá 15 ngày (với phụ huynh xin phép chậm nộp – thời gian chậm nộp không quá ngày 20 của tháng), nhà trường xin phép tạm dừng đón trẻ tới trường mà không cần báo trước. Việc xin phép chậm nộp cần thực hiện trong 7 ngày đầu mỗi tháng.
            <br />

            Đồng thời phụ huynh vui lòng đóng thêm 5%/số chậm thanh toán.
            <br />

            Mọi chi tiết xin vui lòng liên hệ: Ms. Diệp – SĐT: 0911613535
        </span>
    </div>

</body>
</html>