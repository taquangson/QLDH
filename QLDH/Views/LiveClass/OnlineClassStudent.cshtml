


@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <!-- Meta, title, CSS, favicons, etc. -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="~/Assets/kendo/styles/kendo.mobile.all.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.common.min.css" rel="stylesheet" />
    @*<link href="~/Assets/kendo/styles/kendo.rtl.min.css" rel="stylesheet" />*@
    @*<link href="~/Assets/kendo/styles/kendo.bootstrap.min.css" rel="stylesheet" />*@
    <link href="~/Assets/kendo/styles/kendo.bootstrap.mobile.min.css" rel="stylesheet" />
    @*<link href="~/Assets/kendo/kendo.ext.css" rel="stylesheet" />*@
    <link href="~/Assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    @*<link href="~/Assets/custom.min.css" rel="stylesheet" />*@
    <link href="~/Assets/Common.css" rel="stylesheet" />
    <link href="~/Assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="~/Content/onclineclass-student.css" rel="stylesheet" />

    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Assets/kendo/kendo.all.min.js"></script>
    <script src="~/Scripts/jquery.signalR-2.4.1.js"></script>
    <script src="~/signalr/hubs"></script>
    <script src="//sdk.twilio.com/js/video/releases/2.15.3/twilio-video.min.js"></script>
    <script src="~/Scripts/js/onlineclassstudent.js"></script>

</head>

<body>


    <div data-role="view" id="two-drawer-home" data-title="Friends" data-use-native-scrolling="true">
        <header data-role="header">
            <div data-role="navbar">
                <a data-role="button" data-rel="drawer" href="#left-drawer" id="back-button" class="nav-button" data-align="left">
                    <span class="fa fa-users"></span>
                </a>
                <span id="running-text" data-role="view-title">
                    <p id="txtRunning" >On Streamming!...Đang phát trực tiếp!...</p>
                </span>
                @*<a data-align="right" data-icon="source-code" data-click="goToSourceCode" data-role="button" title="Show this demo source code"></a>*@
                <a data-role="button" data-align="right" id="modalview-open-button">
                    <span class="fa fa-comment"></span>
                </a>
                <a data-role="button" onclick="getThongTinLopHoc()" data-align="center" id="start-stream">
                    <span class="fa fa-play-circle-o"></span> Start Stream
                </a>
                <a data-role="button" data-rel="drawer" href="#right-drawer" data-icon="drawer-icon" data-align="right"></a>
            </div>
        </header>
        @*<a class="left-btn" data-role="button" data-rel="drawer" href="#left-drawer" data-icon="comments"></a>*@
        <div data-role="content">
            <div id="remoteTrack" class="video-container">

            </div>
            <div id="participant" class="list-participant">

            </div>
        </div>
    </div>

    <div data-role="drawer" id="left-drawer" style="width: 20em;" data-title="Communities" data-views="['two-drawer-home']" data-use-native-scrolling="true">
        <header data-role="header">
            <div data-role="navbar">
                <span data-role="view-title"></span>
            </div>
        </header>

        <ul id="ul-list-participant" data-role="listview" class="km-listview-icons" style="height:0">
        </ul>
    </div>

    <div data-role="drawer" id="right-drawer" style="width: 7em" data-title="Share" data-position="right" data-views="['two-drawer-home']">
        <div data-role="tabstrip" class="km-vertical-tabstrip">
            <a href="#drawer/two-way-drawers" data-icon="contacts">
                Liên hệ
            </a>
            <a href="#drawer/two-way-drawers" data-icon="history">
                Lịch sử
                @*</a><a href="#drawer/two-way-drawers" data-icon="favorites">
                    Favorites*@
            </a><a onclick="openSettingWindow()" data-icon="settings">Cài đặt</a>
        </div>
    </div>


    <div id="windowChat" style="height:calc(80vh + 5px);display:none">
        <div id="chat"></div>
    </div>

    <div id="windowSettingSource" style="display:none">
        <br />
        <div class="form-group valid">
            <label style="width:100%">Nguồn âm thanh: </label>
            <input id="comboAudio" class="input" />
        </div>
        <div class="form-group valid">
            <label style="width:100%">Nguồn camera: </label>
            <input id="comboVideo" class="input" />
        </div>
    </div>
</body>
</html>

