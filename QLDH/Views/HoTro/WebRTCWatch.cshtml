

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <!-- Meta, title, CSS, favicons, etc. -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="~/Assets/kendo/styles/kendo.mobile.all.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.common.min.css" rel="stylesheet" />
    @*<link href="~/Assets/kendo/styles/kendo.common-bootstrap.min.css" rel="stylesheet" />*@
    <link href="~/Assets/kendo/styles/kendo.rtl.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.bootstrap.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.bootstrap.mobile.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/kendo.ext.css" rel="stylesheet" />
    <link href="~/Assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Assets/custom.min.css" rel="stylesheet" />
    <link href="~/Assets/Common.css" rel="stylesheet" />

    <link href="~/Assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Assets/kendo/kendo.all.min.js"></script>
    <script src="~/Scripts/jquery.signalR-2.4.1.js"></script>
    <script src="~/signalr/hubs"></script>
    <script src="~/Scripts/js/webrtcwatch.js"></script>
    <link href="~/Content/webrtc.css" rel="stylesheet" />
    <script type="text/javascript">
        let peerConnection;
        var servers = { 'iceServers': [{ 'urls': 'stun:stun.services.mozilla.com' }, { 'urls': 'stun:stun.l.google.com:19302' }, { 'urls': 'turn:numb.viagenie.ca', 'credential': 'webrtc', 'username': 'websitebeaver@mail.com' }] };
        var _iceServers = [{ url: 'stun:74.125.142.127:19302' }];
        $.connection.hub.start().done(function () {
            console.log("Connect signalR OK!");
        });
        var signalR = $.connection.boardcastHub;
        var yourId;
        

        signalR.client.push_offer = function (id, description) {
            if (JSON.parse(description).sdp) {
                peerConnection = new RTCPeerConnection({ iceServers: _iceServers });
                peerConnection
                    .setRemoteDescription(JSON.parse(description).sdp)
                    .then(() => peerConnection.createAnswer())
                    .then(sdp => peerConnection.setLocalDescription(sdp))
                    .then(() => {
                        sendMessage(id, JSON.stringify({ "sdp": peerConnection.localDescription }), "answer");
                    });

                peerConnection.ontrack = event => {

                    document.getElementById("video").srcObject = event.streams[0];
                };

                peerConnection.onicecandidate = event => {
                    if (event.candidate) {
                        sendMessage(id, JSON.stringify({ "candidate": event.candidate }), "candidate");
                    } else {
                        console.log("All ICE candidates have been sent");
                    }
                };
            }
        }

        signalR.client.push_candidate = function (id, candidate) {
            
            if (JSON.parse(candidate).candidate) {
                peerConnection
                    .addIceCandidate(new RTCIceCandidate(JSON.parse(candidate).candidate))
                    .catch(e => console.error(e));
            }        
        }

        signalR.client.push_chat = function (id, description) {
            if (parseInt(id) != yourId) {

                $("#chat").data("kendoChat").renderMessage({
                    type: "text",
                    text: description
                }, {
                    id: id,
                    name: id,
                    iconUrl: "../Images/img.png"
                });
            }
        }

        function sendMessage(senderId, value, hubpush) {
            $.ajax({
                url: '/LiveClass/InitCallSession',
                type: 'POST',
                data: { senderId: senderId, message: value, hubname: hubpush }
            }).done(function (response) {

            })
        }

        function createSession() {
            try {
                peerConnection.close();
            } catch {

            }
            yourId = Math.floor(Math.random() * 1000);
            sendMessage(yourId, '', 'watcher');
        }

        window.onunload = window.onbeforeunload = () => {
            peerConnection.close();
        };

    </script>

</head>

<body>

    <div class="meet-container">
        <div class="video-container">
            <div id="video-container" class="video-view">
                <video id="video" autoplay controls>
                </video>
            </div>
            <div class="video-button">
                <button onclick="createSession()" class="k-button"><span class="fa fa-video-camera"></span> <b>Start meeting</b></button>
            </div>
        </div>
        <div class="chat-container">
            <div id="tabstrip">
                <ul>
                    <li class="k-state-active" style="width:50%;text-align:center;">
                        Live Chat
                    </li>
                    <li style="width:50%;text-align:center;">
                        Viewers
                    </li>
                </ul>
                <div>
                    <div id="chat"></div>
                </div>
                <div>
                    <div id="listview"></div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>

