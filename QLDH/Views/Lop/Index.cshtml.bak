@{
    ViewBag.Title = "Quản lý lớp";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .image-preview {
        width: 100px;
        height: 100px;
        object-fit: contain;
    }

    .k-dropdown-wrap.k-state-default, .k-multiselect-wrap {
        border-color: #929090;
    }

    .dahoc {
        background-color: #ffd800;
    }
</style>
<div id="dialogRoot"></div>
<div class="row">
    <h2><b>Danh sách lớp</b></h2>
</div>
<div class="row toolBarMenu">
    <button class="k-button bg-blue" onclick="ThemMoi()"> <i class="fa fa-plus-square"> Thêm </i></button>
    <button class="k-button bg-orange" onclick="openEditWindow()"> <i class="fa fa-wrench"> Sửa</i> </button>
    <button class="k-button bg-red" onclick="Xoa()"> <i class="fa fa-close"> Xóa</i> </button>
    <button class="k-button bg-green" onclick="XuatExcel()"> <i class="fa fa-file-excel-o"> Xuất excel</i> </button>
</div>
<div class="row">
    <div id="grid"></div>
</div>

<div style="visibility:hidden" id="window">
    <div class="toolBarMenu">
        <button class="k-button bg-blue" onclick="Luu()"> <i class="fa fa-plus-square"> Lưu </i></button>
        <button class="k-button bg-red" onclick="Huy()"> <i class="fa fa-close"> Hủy</i> </button>
    </div>
    <form id="formChiTiet">
        <div class="form-group">
            <input id="ID" type="hidden" />
        </div>
        <div class="form-group valid" toggle-valid="TenLop">
            <label style="width:100%">Tên lớp: <span style="color:red">*</span></label>
            <input id="TenLop" placeholder="Tên lớp" type="text" class="k-textbox input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group" toggle-valid="PhongHoc">
            <label style="width:100%">Phòng học:</label>
            <input id="PhongHoc" placeholder="Phòng học" type="text" class="k-textbox" />
        </div>
        <div class="form-group valid" toggle-valid="KhoiCombo">
            <label style="width:100%">Khối: <span style="color:red">*</span></label>
            <input id="KhoiCombo" class="input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="GiaoVienCombo">
            <label style="width:100%">Giáo viên: <span style="color:red">*</span></label>
            <input id="GiaoVienCombo" class="input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
        <div class="form-group valid" toggle-valid="GiaoVienCombo">
            <label style="width:100%">Quản sinh: </label>
            <input id="QuanSinhCombo" class="input" />
        </div>
        <div class="form-group">
            <label style="width:100%">Lịch học: </label>
            <div id="gridLichHoc"></div>
        </div>
        <div class="form-group valid" toggle-valid="CongThucHocPhiComBo">
            <label style="width:100%">Học phí: <span style="color:red">*</span></label>
            <input id="CongThucHocPhiCombo" class="input" />
            <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
        </div>
    </form>
</div>
<div id="windowChitiet">
    <input type="hidden" id="IDLop" />
    <div class="toolBarMenu">
        <button class="k-button bg-blue" onclick="LuuChiTietLop()"> <i class="fa fa-plus-square"> Lưu </i></button>
        <button class="k-button bg-red" onclick="HuyChiTietLop()"> <i class="fa fa-close"> Hủy</i> </button>
        <button class="k-button bg-green" onclick="XuatExcelHocSinh()"> <i class="fa fa-file-excel-o"> Xuất excel</i> </button>
    </div>
    <div style="width:50%;float:left;text-align:center">
        <h5><b>Học sinh trong lớp</b></h5>
    </div>
    <div style="width:50%;float:left;text-align:center">
        <h5><b>Học sinh ngoài lớp</b></h5>
    </div>
    <div style="width:49.5%;float:left" id="gridHocSinhTrongLop"></div>
    @*<div style="width:1%;float:left"></div>*@
    <div style="width:50%;float:left" id="gridHocSinhNgoaiLop"></div>
</div>

<div id="windowGiaoAn">
    <input type="hidden" id="IDLopGiaoAn" />
    <div class="toolBarMenu">
        <a style="color:orangered">Nhắc nhở soạn giáo án cho lớp </a>
        <label style="color:black" id="tenlop"></label>
        -
        <input id="ngayhoc" />
        <button class="k-button bg-blue" onclick="pushNoti()"> <i class="fa fa-envelope"> Gửi nhắc nhở </i></button>
    </div>
    <div style="width:99%" id="gridGiaoAn"></div>
</div>
<script src="~/Scripts/js/lop.js"></script>