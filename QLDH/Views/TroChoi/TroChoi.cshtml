@{
    ViewBag.Title = "Kho dữ liệu trò chơi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using QLDH.DataAccess.Models
@{
    TaiKhoanModel userinfor = (TaiKhoanModel)Session["UserInfor"];
}
<script src="~/Scripts/js/khotrochoi.js"></script>
<div id="dialogRoot"></div>
<div id="rootContainer" style="display:none">
    <div class="row">
        <h2><b>Kho trò chơi</b></h2>
    </div>
    <div class="row">
        <div id="gridCauHoi"></div>
    </div>
    <div id="windowCauHoi">
        <div class="toolBarMenu">
            <button class="k-button bg-blue" onclick="LuuCauHoi()"> <i class="fa fa-plus-square"> Lưu </i></button>
            <button class="k-button bg-red" onclick="HuyCauHoi()"> <i class="fa fa-close"> Hủy</i> </button>
        </div>

        <form id="formCauHoi">
            <div style="width:100%">
                <input type="hidden" id="ID_TroChoi" />
                <div style="width:48%;float:left;margin-left:2%">
                    <div class="valid" toggle-valid="DanhMuc">
                        <label style="width:100%;margin-top:7px;">Tên trò chơi: <span style="color:red">*</span></label>
                        <input id="TenTroChoi" class="input k-textbox" />
                        <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
                    </div>
                    <div class="valid" toggle-valid="LoaiTroChoi">
                        <label style="width:100%">Loại: <span style="color:red">*</span></label>
                        <input id="LoaiTroChoi" class="input" />
                        <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
                    </div>
                    <div class="valid" toggle-valid="NoiDung">
                        <label style="width:100%;margin-top:7px;">Nội dung: <span style="color:red">*</span></label>
                        <textarea id="NoiDung" style="width:100%;height:700px;" rows="2" class="k-textbox"></textarea>
                        <span class="fa fa-exclamation-triangle icon" title="Không được bỏ trống"></span>
                    </div>
                    <div class="valid">
                        <label style="width:100%;margin-top:7px;">Hình ảnh: </label>
                        <input id="HinhAnh" type="file" />
                        <input id="HinhAnhFile" type="hidden" />
                    </div>
                    <div class="valid">
                        <label style="width:100%;margin-top:7px;">Âm thanh: </label>
                        <input id="AmThanh" type="file" />
                        <input id="AmThanhFile" type="hidden" />
                    </div>
                </div>
                <div style="width:48%;float:left;margin-left:2%">
                    <label style="width:100%;margin-top:7px;">Đáp án: <span style="color:red">*</span></label>
                    <div id="gridDapAn"></div>
                </div>
            </div>
        </form>
    </div>
</div>