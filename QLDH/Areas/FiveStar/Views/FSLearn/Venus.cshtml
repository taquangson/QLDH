    <div class="container-fluid">
        <div class="row">
            <div id="tabstrip">
                <ul>
                    <li class="k-active">
                        Look, Listen And Type
                    </li>
                    <li>
                        Look, Listen And Click
                    </li>
                    <li>
                        Look, Listen And Choose
                    </li>
                    <li>
                        Look, Type And Repeat
                    </li>
                    <li>
                        Grammar Quiz
                    </li>
                </ul>
                <div>
                    <div>
                        @{
                            int index = 1;
                            string[] Ans = { "A", "B", "C", "D", "E", "F", "G", "H", "I" };
                        }
                        @foreach (QLDH.DataAccess.Models.CauHoiModel ch in Model.ChiTietBaiGiang[0].lstLookListenAndType)
                        {
                            <div class="question-info" id="question-@ch.ID">
                                <h4 class="question-count"><b>Question @(index++)</b></h4>
                                <div class="question-content">
                                    <div>@Html.Raw(ch.NoiDungCauHoi)</div>

                                    @foreach (QLDH.DataAccess.Models.DapAnModel da in ch.lstDapAn)
                                    {
                                        if (da.IsDapAnDung == 1)
                                        {
                                            <div class="list-answer">
                                                <input id="correct-@da.ID-@ch.ID" type="hidden" value="@da.DapAn" />
                                                <table border="1" class="typTable">
                                                    <tr>
                                                        @for (int cc = 0; cc < da.DapAn.Length; cc++)
                                                        {
                                                            <td></td>
                                                        }
                                                    </tr>
                                                </table>
                                                <input id="answer-@da.ID-@ch.ID" class="typInput" maxlength="@da.DapAn.Length" @*value="@da.DapAn"*@ type="text" />
                                            </div>
                                        }
                                    }
                                </div>
                                <div style=" margin-top: 50px;">
                                    <button class="k-button" onclick="checkandnext(@ch.ID)">Check</button>
                                </div>
                            </div>
                        }
                        <div class="question-info" style="text-align:center">
                            <img class="endSectionCongra" src="~/Areas/FiveStar/Images/congra.gif" />
                        </div>
                    </div>
                </div>
