@{
    ViewBag.Title = "Learnning";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<script src="~/Areas/FiveStar/Scripts/animatelo.min.js"></script>
<link href="~/Areas/FiveStar/Content/css/venus.css" rel="stylesheet" />
<script>
    var doneFlashCard = false;
    $(document).ready(function () {
        $("#tabstrip").kendoTabStrip({
            animation: {
                open: {
                    effects: "fadeIn"
                }
            },
            change: function (e) {
                console.log(e.sender.select());
                $("#tabstrip-" + (e.sender.select().index() + 1) + " .question-info").hide();
                $("#tabstrip-" + (e.sender.select().index() + 1) + " .question-info").first().show();
                window.animatelo.bounceInLeft("#tabstrip-" + (e.sender.select().index() + 1) + " .question-info:first-child", {
                    duration: 800
                })
            }
        });
        //window.animatelo.pulse('.img', {
        //    duration: 1500
        //}); $(".img").show()
        $(".card").hide();
        $(".card").first().show();

        $(".question-info").hide();
        $(".question-info").first().show();

        $("#windowCongra").kendoWindow({
            title: "",
            visible: false,
            modal: true,
            resizable: false,
            actions: [
                "Close"
            ],
            open: function () {
                document.getElementById("audioCongra").play();

            }
        });
    });


    function updateDapAn(tag) {
        //console.log(tag);
        $(".answer-item").removeClass("choose");
        $(tag).parent().addClass("choose")
    }

    function checkandnext(idcauhoi) {
        inputs = $("#question-" + idcauhoi).find(".list-answer input");
        isTrue = true;
        for (var i = 0; i < inputs.length; i = i + 2) {
            var cor = $(inputs[i]).val().toLowerCase();
            var ans = $(inputs[i + 1]).val().toLowerCase();
            isTrue = isTrue && (cor == ans);
        }

        if (isTrue) {
            showCongra();
            setTimeout(() => {
                $("#question-" + idcauhoi).hide();
                var nextid = "";
                if ($("#question-" + idcauhoi).next().length == 0) {
                    $(".question-info").first().show();
                    nextid = $(".question-info").first().attr("id");
                } else {
                    $("#question-" + idcauhoi).next().show();
                    nextid = $("#question-" + idcauhoi).next().attr("id");
                }
                window.animatelo.bounceInLeft("#" + nextid, {
                    duration: 800
                })
            }, 2000);
        } else {
            window.animatelo.pulse("#answer-" + idcauhoi, {
                duration: 200
            })
            document.getElementById("audioError").play();
        }
    }

    function checkandnext2(idcauhoi) {
        //console.log(/*$(".choose").attr('class').indexOf("istrue-1")*/);
        if ($(".choose").attr('class').indexOf("istrue-1") > 0) {
            window.animatelo.bounceOut("#question-" + idcauhoi, {
                duration: 800
            })
            showCongra();
            setTimeout(() => {
                $("#question-" + idcauhoi).hide();
                var nextid = "";
                if ($("#question-" + idcauhoi).next().length == 0) {
                    $(".question-info").first().show();
                    nextid = $(".question-info").first().attr("id");
                } else {
                    $("#question-" + idcauhoi).next().show();
                    nextid = $("#question-" + idcauhoi).next().attr("id");
                }
                window.animatelo.bounceInLeft("#" + nextid, {
                    duration: 800
                })
            }, 2000);
        } else {
            window.animatelo.pulse(".list-answer", {
                duration: 200
            })
            document.getElementById("audioError").play();
        }
        $(".answer-item").removeClass("choose");
        $('input[type=radio]').prop('checked', false);
    }

    function showCongra() {
        $("#windowCongra").data("kendoWindow").center().open();
        setTimeout(function () { $("#windowCongra").data("kendoWindow").close(); }, 2000);
    }
</script>
<div id="windowCongra">
    <img class="imgCongra" src="~/Areas/FiveStar/Images/youarestar.gif" />
    <audio id="audioCongra" style="display:none" controls="">
        <source src="https://luyenthiduonghoa.vn/Content/UserFiles/FileServer/Files/FiveStar/Video/MOON_1/mixkit-final-level-bonus-2061.mp3" type="audio/mpeg"></source>
    </audio>

</div>
<audio id="audioError" style="display:none" controls="">
    <source src="https://luyenthiduonghoa.vn/Content/UserFiles/FileServer/Files/FiveStar/Video/MOON_1/mixkit-wrong-electricity-buzz-955.mp3" type="audio/mpeg"></source>
</audio>
<div style="width:100%;background-color:#fff">
