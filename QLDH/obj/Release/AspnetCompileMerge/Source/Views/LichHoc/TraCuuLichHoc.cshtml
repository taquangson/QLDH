
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Tra cứu lich học - Trung tâm luyện thi Dương Hòa</title>
    <link href="~/Assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="~/Assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.mobile.all.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.common.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.rtl.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.bootstrap.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.bootstrap.mobile.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/kendo.ext.css" rel="stylesheet" />
    <link href="~/Assets/tracuulichhoc.css" rel="stylesheet" />
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Assets/kendo/kendo.all.min.js"></script>
    <script src="~/Scripts/jszip.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $.ajax({
                url: '/User/GetAllChiNhanh',
                type: 'GET',
            }).done(function successCallback(response) {
                var dt = [];
                dt.push({ TenChiNhanh: "Tất cả", ID: 0, NgayTao: null });
                $.each(response, function (index, item) {
                    dt.push(item);
                })
                var dataSource = new kendo.data.DataSource({
                    data: response,
                });
                $("#ComboChiNhanh").kendoComboBox({
                    dataTextField: "TenChiNhanh",
                    dataValueField: "ID",
                    placeholder: "Chi nhánh",
                    filter: "contains",
                    suggest: true,
                    delay: 1000,
                    clearButton: false,
                    dataSource: dt,
                    change: function (e) {
                        LoadComboLop($("#comboKhoi").data("kendoComboBox").value());
                    }
                })
                $("#ComboChiNhanh").data("kendoComboBox").value(0);


                $("#comboKhoi").kendoComboBox({
                    dataTextField: 'text',
                    dataValueField: 'value',
                    placeholder: "Khối",
                    clearButton: false,
                    dataSource: new kendo.data.DataSource({
                        data: [
                            { text: 'Tất cả', value: 0 },
                            { text: '1', value: 1 },
                            { text: '2', value: 2 },
                            { text: '3', value: 3 },
                            { text: '4', value: 4 },
                            { text: '5', value: 5 },
                            { text: '6', value: 6 },
                            { text: '7', value: 7 },
                            { text: '8', value: 8 },
                            { text: '9', value: 9 },
                            { text: '10', value: 10 },
                            { text: '11', value: 11 },
                            { text: '12', value: 12 },
                        ]
                    }),
                    change: function (e) {
                        LoadComboLop(e.sender.value());
                    }
                });
                $("#comboKhoi").data("kendoComboBox").value(0);
                $("#comboLop").kendoMultiSelect({
                    dataTextField: 'TenLop',
                    dataSource: {
                        data: []
                    },
                    height: 200,
                    dataValueField: 'ID',
                    autoClose: false,
                    footerTemplate: '<b onclick="comboLop_SelectAll()" class="btn-multiselect-selectall">Chọn tất cả</b>'
                });
                LoadComboLop(0);
            });
        })

        function comboLop_SelectAll() {
            var multi = $("#comboLop").data("kendoMultiSelect");
            var values = $.map(multi.dataSource.data(), function (dataItem) {
                return dataItem.ID;
            });
            console.log(values);
            multi.value(values);
        }

        function LoadLichHoc() {
            var idlop = $("#comboLop").data("kendoMultiSelect").value();
            console.log(idlop);
            if (idlop == []) {
                idlop = [0];
            }
            $.ajax({
                url: '/LichHoc/TraCuuLich',
                data: {
                    GioBatDau: '00:00:00',
                    GioKetThuc: '12:00:00',
                    ID_Lop: idlop
                },
                type: 'POST',
            }).done(function successCallback(response) {
                for (var i = 1; i <= 7; i++) {
                    html = "";
                    var lstCa = []
                    $.each(response.filter(function (st) { return st.Thu == i; }), function (index, item) {
                        if (lstCa.indexOf(item.TenCa) < 0) {
                            lstCa.push(item.TenCa);
                        }
                    })

                    $.each(lstCa, function (index, item) {
                        html += "</br><b style='color:#466b90'>" + item + "</b>";
                        $.each(response.filter(function (st) { return st.Thu == i; }), function (index2, item2) {
                            if (item2.TenCa == item) {
                                html += "</br> - " + item2.TenLop;
                            }
                        })
                    })
                    $("#sang" + i).html(html);
                }
            });

            $.ajax({
                url: '/LichHoc/TraCuuLich',
                data: {
                    GioBatDau: '12:00:00',
                    GioKetThuc: '18:00:00',
                    ID_Lop: idlop
                },
                type: 'POST',
            }).done(function successCallback(response) {
                for (var i = 1; i <= 7; i++) {
                    html = "";
                    var lstCa = []
                    $.each(response.filter(function (st) { return st.Thu == i; }), function (index, item) {
                        if (lstCa.indexOf(item.TenCa) < 0) {
                            lstCa.push(item.TenCa);
                        }
                    })

                    $.each(lstCa, function (index, item) {
                        html += "</br><b style='color:#466b90'>" + item + "</b>";
                        $.each(response.filter(function (st) { return st.Thu == i; }), function (index2, item2) {
                            if (item2.TenCa == item) {
                                html += "</br> - " + item2.TenLop;
                            }
                        })
                    })
                    $("#chieu" + i).html(html);
                }
            });

            $.ajax({
                url: '/LichHoc/TraCuuLich',
                data: {
                    GioBatDau: '18:00:00',
                    GioKetThuc: '23:00:00',
                    ID_Lop: idlop
                },
                type: 'POST',
            }).done(function successCallback(response) {
                for (var i = 1; i <= 7; i++) {
                    html = "";
                    var lstCa = []
                    $.each(response.filter(function (st) { return st.Thu == i; }), function (index, item) {
                        if (lstCa.indexOf(item.TenCa) < 0) {
                            lstCa.push(item.TenCa);
                        }
                    })

                    $.each(lstCa, function (index, item) {
                        html += "</br><b style='color:#466b90'>" + item + "</b>";
                        $.each(response.filter(function (st) { return st.Thu == i; }), function (index2, item2) {
                            if (item2.TenCa == item) {
                                html += "</br> - " + item2.TenLop;
                            }
                        })
                    })
                    $("#toi" + i).html(html);
                }
            });
        }
        function LoadComboLop(khoi) {
            $.ajax({
                url: '/Lop/GetAllByChiNhanh?ID_ChiNhanh=' + $("#ComboChiNhanh").data("kendoComboBox").value(),
                type: 'GET',
            }).done(function successCallback(response) {
                var ds = [];
                if (khoi > 0) {
                    ds = response.filter(x => parseInt(x.TenLop.substring(0, 2)) == parseInt(khoi));
                } else {
                    ds = response;
                }
                var dataSource = new kendo.data.DataSource({
                    data: ds
                });
                $("#comboLop").data("kendoMultiSelect").setDataSource(dataSource);
                $("#comboLop").data("kendoMultiSelect").value([]);
            });
        }

/**/</script>
</head>

<body>
    <div class="form-group">
        <div class="col-sm-3">
            <label class="lb-find">Chi nhánh: </label>
            <input class="control-find" id="ComboChiNhanh" />
        </div>
        <div class="col-sm-3">
            <label class="lb-find">Khối: </label>
            <input class="control-find" id="comboKhoi" />
        </div>
        <div class="col-sm-6">
            <label class="lb-find">Lớp: </label>
            <div class="control-find" id="comboLop" />
        </div>
    </div>
    <div class="row text-center">
        <a class="btn btn-default pdtop" onclick="LoadLichHoc()">Tìm kiếm lịch</a>
    </div>
    <table border="1">
        <tr>
            <td style="width:12%"></td>
            <td style="width:12%;text-align:center;font-weight:600;font-size:16px;">Chủ nhật</td>
            <td style="width:12%;text-align:center;font-weight:600;font-size:16px;">Thứ 2</td>
            <td style="width:12%;text-align:center;font-weight:600;font-size:16px;">Thứ 3</td>
            <td style="width:12%;text-align:center;font-weight:600;font-size:16px;">Thứ 4</td>
            <td style="width:12%;text-align:center;font-weight:600;font-size:16px;">Thứ 5</td>
            <td style="width:12%;text-align:center;font-weight:600;font-size:16px;">Thứ 6</td>
            <td style="width:12%;text-align:center;font-weight:600;font-size:16px;">Thứ 7</td>
        </tr>
        <tr>
            <td style="vertical-align:middle;text-align:center;color:coral;font-size:20px;font-weight:600">Sáng</td>
            <td id="sang1"></td>
            <td id="sang2"></td>
            <td id="sang3"></td>
            <td id="sang4"></td>
            <td id="sang5"></td>
            <td id="sang6"></td>
            <td id="sang7"></td>
        </tr>
        <tr>
            <td style="vertical-align:middle;text-align:center;color:coral;font-size:20px;font-weight:600">Chiều</td>
            <td id="chieu1"></td>
            <td id="chieu2"></td>
            <td id="chieu3"></td>
            <td id="chieu4"></td>
            <td id="chieu5"></td>
            <td id="chieu6"></td>
            <td id="chieu7"></td>
        </tr>
        <tr>
            <td style="vertical-align:middle;text-align:center;color:coral;font-size:20px;font-weight:600">Tối</td>
            <td id="toi1"></td>
            <td id="toi2"></td>
            <td id="toi3"></td>
            <td id="toi4"></td>
            <td id="toi5"></td>
            <td id="toi6"></td>
            <td id="toi7"></td>
        </tr>
    </table>

</body>
</html>
