<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <!-- Meta, title, CSS, favicons, etc. -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewBag.Title - Hệ thống quản lý giáo dục công ty Dương Hòa</title>

    <link href="~/Assets/kendo/styles/kendo.mobile.all.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.common.min.css" rel="stylesheet" />
    @*<link href="~/Assets/kendo/styles/kendo.common-bootstrap.min.css" rel="stylesheet" />*@
    <link href="~/Assets/kendo/styles/kendo.rtl.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.bootstrap.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/styles/kendo.bootstrap.mobile.min.css" rel="stylesheet" />
    <link href="~/Assets/kendo/kendo.ext.css" rel="stylesheet" />
    <link href="~/Assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Assets/custom.min.css" rel="stylesheet" />
    <link href="~/Assets/Common.css" rel="stylesheet" />

    <link href="~/Assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet"/>
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="http://cdnjs.cloudflare.com/ajax/libs/jszip/2.4.0/jszip.js"></script>
</head>
@using QLDH.DataAccess.Models
@{
    TaiKhoanModel userinfor = (TaiKhoanModel)Session["UserInfor"];
}
<body class="nav-md">
    <div class="container body">
        <div class="main_container">
            <div class="col-md-3 left_col">
                <div class="left_col scroll-view">
                    <div class="navbar nav_title" style="border: 0;">
                        <a href="/Home/Index" class="site_title"><i class="fa fa-book"></i> <span>E - Manager</span></a>
                    </div>

                    <div class="clearfix"></div>

                    <!-- menu profile quick info -->
                    <div class="profile clearfix">
                        <div class="profile_pic">
                            <img src="~/Images/img.jpg" alt="..." class="img-circle profile_img">
                        </div>
                        <div class="profile_info">
                            <span>Xin chào,</span>
                            <h2>@userinfor.TenDayDu</h2>
                        </div>
                    </div>
                    <!-- /menu profile quick info -->

                    <br />

                    <!-- sidebar menu -->
                    <div id="sidebar-menu" class="main_menu_side hidden-print main_menu">
                        <div class="menu_section">
                            <h3>Danh sách chức năng</h3>
                            <ul class="nav side-menu">
                                <li>
                                    <a>
                                        <i class="fa fa-home"></i> Danh mục hệ thống <span class="fa fa-chevron-right"></span>
                                        <span class="fa fa-chevron-down"></span>
                                    </a>
                                    <ul class="nav child_menu">
                                        @{ if (userinfor.Role == 1)
                                            {
                                                <li><a href="/Lop/Index">Danh sách lớp học</a></li>
                                                <li><a href="/HocSinh/Index">Danh sách học sinh</a></li>
                                                <li><a href="/User/Index">Danh sách nhân sự</a></li>
                                            }
                                            else
                                            {
                                                <li><a href="/Lop/DanhSachLopTheoGiaoVien">Danh sách lớp học</a></li>
                                            }
                                        }
                                    </ul>
                                </li>
                                <li>
                                    <a>
                                        <i class="fa fa-cogs"></i> Chức năng hệ thống <span class="fa fa-chevron-right"></span>
                                        <span class="fa fa-chevron-down"></span>
                                    </a>
                                    <ul class="nav child_menu">
                                        <li><a href="/DiemDanh/Index">Điểm danh học sinh</a></li>
                                        @{ if (userinfor.Role == 1)
                                            {
                                                <li><a href="/DiemDanh/QuanLyDuLieuDiemDanh">Dữ liệu điểm danh học sinh</a></li>
                                                <li><a href="/PhieuHoc/Index">Quản lý phiếu vào lớp</a></li>
                                                <li><a href="/PhieuThu/Index">Quản lý thanh toán học phí</a></li>
                                            }
                                        }
                                    </ul>
                                </li>
                                <li>
                                    <a>
                                        <i class="fa fa-line-chart"></i> Báo cáo hệ thống <span class="fa fa-chevron-right"></span>
                                        <span class="fa fa-chevron-down"></span>
                                    </a>
                                    <ul class="nav child_menu">
                                        @{ if (userinfor.Role == 1)
                                            {
                                                <li><a href="/BaoCao/ThongKeBuoiHocTheoHocSinh">Thống kê buổi học theo học sinh</a></li>

                                                <li><a href="/BaoCao/BaoCaoPhieuHocTheoHocSinh">Báo cáo phiếu học theo học sinh</a></li>
                                                <li><a href="/BaoCao/Index">Thống kê học sinh sắp hết phiếu</a></li>
                                            }
                                        }
                                        <li><a href="/BaoCao/Index">Thống kê buổi dạy của giáo viên</a></li>
                                    </ul>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <!-- /sidebar menu -->
                    <!-- /menu footer buttons -->
                    @*<div class="sidebar-footer hidden-small">
                            <a data-toggle="tooltip" data-placement="top" title="Settings">
                                <span class="glyphicon glyphicon-cog" aria-hidden="true"></span>
                            </a>
                            <a data-toggle="tooltip" data-placement="top" title="FullScreen">
                                <span class="glyphicon glyphicon-fullscreen" aria-hidden="true"></span>
                            </a>
                            <a data-toggle="tooltip" data-placement="top" title="Lock">
                                <span class="glyphicon glyphicon-eye-close" aria-hidden="true"></span>
                            </a>
                            @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm" }))
                            {
                            @Html.AntiForgeryToken()
                            <a data-toggle="tooltip" data-placement="top" title="Đăng xuất" href="javascript:document.getElementById('logoutForm').submit()">
                                <span class="glyphicon glyphicon-off" aria-hidden="true"></span>
                            </a>
                            }

                        </div>*@
                    <!-- /menu footer buttons -->
                </div>
            </div>

            <!-- top navigation -->
            <div class="top_nav">
                <div class="nav_menu">
                    <nav>
                        <div class="nav toggle">
                            <a id="menu_toggle"><i class="fa fa-bars"></i></a>
                        </div>
                        @using (Html.BeginForm("LogOff", "User", FormMethod.Post, new { id = "logoutForm" }))
                        {
                            <ul class="nav navbar-nav navbar-right">
                                <li class="">
                                    <a href="javascript:;" class="user-profile dropdown-toggle" data-toggle="dropdown" aria-expanded="false">
                                        <img src="~/Images/img.jpg" alt="">@userinfor.TenDayDu
                                        <span class="fa fa-angle-down"></span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-usermenu pull-right">
                                        <li><a href="/User/ChangePass"> Đổi mật khẩu</a></li>
                                        <li><a href="javascript:;">Hỗ trợ</a></li>
                                        <li>
                                            @Html.AntiForgeryToken()
                                            <a title="Đăng xuất" href="javascript:document.getElementById('logoutForm').submit()">
                                                <i class="fa fa-sign-out pull-right"></i>Đăng xuất
                                            </a>
                                        </li>
                                    </ul>
                                </li>

                                <li role="presentation" class="dropdown">
                                    <a href="javascript:;" class="dropdown-toggle info-number" data-toggle="dropdown" aria-expanded="false">
                                        <i class="fa fa-envelope-o"></i>
                                        <span class="badge bg-green">6</span>
                                    </a>
                                    <ul id="menu1" class="dropdown-menu list-unstyled msg_list" role="menu">
                                        <li>
                                            <a>
                                                <span class="image"><img src="~/Images/img.jpg" alt="Profile Image" /></span>
                                                <span>
                                                    <span>John Smith</span>
                                                    <span class="time">3 mins ago</span>
                                                </span>
                                                <span class="message">
                                                    Film festivals used to be do-or-die moments for movie makers. They were where...
                                                </span>
                                            </a>
                                        </li>
                                        <li>
                                            <a>
                                                <span class="image"><img src="~/Images/img.jpg" alt="Profile Image" /></span>
                                                <span>
                                                    <span>John Smith</span>
                                                    <span class="time">3 mins ago</span>
                                                </span>
                                                <span class="message">
                                                    Film festivals used to be do-or-die moments for movie makers. They were where...
                                                </span>
                                            </a>
                                        </li>
                                        <li>
                                            <a>
                                                <span class="image"><img src="~/Images/img.jpg" alt="Profile Image" /></span>
                                                <span>
                                                    <span>John Smith</span>
                                                    <span class="time">3 mins ago</span>
                                                </span>
                                                <span class="message">
                                                    Film festivals used to be do-or-die moments for movie makers. They were where...
                                                </span>
                                            </a>
                                        </li>
                                        <li>
                                            <a>
                                                <span class="image"><img src="~/Images/img.jpg" alt="Profile Image" /></span>
                                                <span>
                                                    <span>John Smith</span>
                                                    <span class="time">3 mins ago</span>
                                                </span>
                                                <span class="message">
                                                    Film festivals used to be do-or-die moments for movie makers. They were where...
                                                </span>
                                            </a>
                                        </li>
                                        <li>
                                            <div class="text-center">
                                                <a>
                                                    <strong>See All Alerts</strong>
                                                    <i class="fa fa-angle-right"></i>
                                                </a>
                                            </div>
                                        </li>
                                    </ul>
                                </li>
                            </ul>
                        }


                    </nav>
                </div>
            </div>
            <!-- /top navigation -->
            <!-- page content -->
            <div class="right_col" role="main" style="padding-top:20px;overflow:scroll;height:calc(100vh-58px);">
                @RenderBody()
            </div>
            <!-- /page content -->
            <!-- footer content -->
            <footer>
                <div class="pull-left">
                    <p>Website developed by QS - quangson0409@gmail.com</p>
                </div>
                <div class="pull-right">
                    Gentelella - Bootstrap Admin Template by <a href="https://colorlib.com">Colorlib</a>
                </div>
                <div class="clearfix"></div>
            </footer>
            <!-- /footer content -->
        </div>
    </div>
    <script id="errorTemplate" type="text/x-kendo-template">
        <div class="wrong-pass">
            <i class="fa fa-close" style="color:red;font-size:40px;"></i>
            <p>#= kValue # </p>
        </div>
    </script>
    <script id="successTemplate" type="text/x-kendo-template">
        <div class="upload-success">
            <i class="fa fa-check" style="color:green;font-size:40px;"></i>
            <p>#= kValue # </p>
        </div>
    </script>
    <div id="dialogRoot"></div>
    <div style="visibility:hidden" id="LayoutWindow">
        <div id="LayoutWindowContent"></div>
    </div>
    @Scripts.Render("~/bundles/vendor")
    @RenderSection("scripts", required: false)
</body>
</html>
