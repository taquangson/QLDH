@{
    Layout = "";
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Công ty giáo dục Dương Hòa - In hóa đơn</title>
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            margin: 0 20px;
        }

        tbody td {
            font-size: 10px;
        }
    </style>
    <script>
        window.onload = function () {
            openConfirm();
            
        }
        function openConfirm() {
            let value = prompt("1 - NB; 2 - TĐ", "1");
            if (value == "1") {
                document.getElementById("qr-nb").style.display = "block";
                document.getElementById("qr-td").style.display = "none";
                window.print();
            } else if (value == "2") {
                document.getElementById("qr-nb").style.display = "none";
                document.getElementById("qr-td").style.display = "block";
                window.print();
            } else {
                openConfirm();
            }
        }
    </script>
</head>
<body>
    <div class="row">
        <h5 class="text-center"><b style="text-transform:uppercase;font-size:13px;">Cty TNHH Giáo Dục CLC Dương Hoà</b></h5>
        <h6 class="text-center">@Model.TaiKhoan.DiaChiChiNhanh</h6>
        <h6 class="text-center">@Model.TaiKhoan.DienThoaiChiNhanh</h6>
        <h6 class="text-center"><b>Mã hóa đơn: @Model.PhieuThu.MaPhieu</b></h6>
        <p class="text-center" style="border-bottom:dashed 1px"></p>
        <h4 class="text-center" style="margin-top:20px;margin-bottom:20px;"><b>PHIẾU THANH TOÁN HỌC PHÍ</b></h4>
        <p style="font-size:10px;width:50%;float:left">Ngày lập: @Model.PhieuThu.NgayTao.ToString("dd/MM/yyyy HH:mm")</p>
        <p style="font-size:10px;width:50%;float:left;text-align:right">Người lập: @Model.PhieuThu.NguoiLap</p>
        <p style="font-size:10px;width:100%;float:left;text-align:left">Người nộp: <b>@Model.PhieuThu.TenHocSinh</b></p>

        <b style="margin-top:20px;display:block">Đơn chính</b>
        <table style="margin:2px;width:100%" border="1">
            <thead>
                <tr style="border-bottom:solid 1px;">
                    @*<td style="width:10%;text-align:center">STT</td>*@
                    <td style="width:40%;text-align:center">Lớp</td>
                    <td style="width:20%;text-align:center">Tháng</td>
                    <td style="width:20%;text-align:center">Số buổi</td>
                    <td style="width:20%;text-align:center">Thành tiền</td>
                </tr>
            </thead>
            <tbody style="border-bottom: solid 1px;">
                @{int i = 0; }
                @foreach (QLDH.DataAccess.Models.PhieuHocModel ph in Model.PhieuThu.lstPhieuHoc)
                {
                    i++;
                    <tr>
                        @*<td style="text-align:center">@i</td>*@
                        <td style="text-align:left">@ph.TenLop</td>
                        <td style="text-align:center">Tháng @ph.Thang </td>
                        <td style="text-align:center">@ph.SoBuoi buổi</td>
                        <td style="text-align:right;">@ph.SoTien.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>



        <b style="margin-top:20px;display:block">Phụ thu</b>
        <table style="margin:2px;width:100%" border="1">
            <thead>
                <tr style="border-bottom:solid 1px;">
                    @*<td style="width:10%;text-align:center">STT</td>*@
                    @*<td style="width:60%;text-align:center">Nội dung</td>
                        <td style="width:30%;text-align:center">Thành tiền</td>*@
                    <td style="width:40%;text-align:center">Lớp</td>
                    <td style="width:20%;text-align:center">Tháng</td>
                    <td style="width:20%;text-align:center">Số buổi</td>
                    <td style="width:20%;text-align:center">Thành tiền</td>
                </tr>
            </thead>
            <tbody style="border-bottom: solid 1px;">
                @{int j = 0; }
                @foreach (QLDH.DataAccess.Models.PhuThuGiamTruModel pt in Model.PhieuThu.lstPhuThu)
                {
                    j++;
                    <tr>
                        @*<td style="text-align:center">@i</td>*@
                        <td style="text-align:left">@pt.TenLop</td>
                        <td style="text-align:center">Tháng @pt.Thang </td>
                        <td style="text-align:center">@pt.SoBuoi buổi</td>
                        <td style="text-align:right;">@pt.DonGia.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>



        <b style="margin-top:20px;display:block">Giảm trừ</b>
        <table style="margin:2px;width:100%" border="1">
            <thead>
                <tr style="border-bottom:solid 1px;">
                    @*<td style="width:10%;text-align:center">STT</td>*@
                    @*<td style="width:60%;text-align:center">Nội dung</td>
                        <td style="width:30%;text-align:center">Thành tiền</td>*@
                    <td style="width:40%;text-align:center">Lớp</td>
                    <td style="width:20%;text-align:center">Tháng</td>
                    <td style="width:20%;text-align:center">Số buổi</td>
                    <td style="width:20%;text-align:center">Thành tiền</td>
                </tr>
            </thead>
            <tbody style="border-bottom: solid 1px;">
                @{int k = 0; }
                @foreach (QLDH.DataAccess.Models.PhuThuGiamTruModel pt in Model.PhieuThu.lstGiamTru)
                {
                    k++;
                    <tr>
                        @*<td style="text-align:center">@k</td>*@
                        <td style="text-align:left">@pt.TenLop</td>
                        <td style="text-align:center">Tháng @pt.Thang </td>
                        <td style="text-align:center">@pt.SoBuoi buổi</td>
                        <td style="text-align:right;">@pt.DonGia.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>
        <p class="text-right"><b>Tổng:  @Model.PhieuThu.TongThu.ToString("N0") VNĐ</b></p>
        <div id="qr-nb" style="display:none" class="col-sm-12">
            <p class="text-center" style="border-top:dashed 1px; font-size:10px;vertical-align:top">
                Chuyển khoản - CN Ninh Bình: 7900167896666 - Tạ Thị Thanh Nga - MB Bank
            </p>
            <img style="width: 190px; margin: auto;display:block"
                 src="https://img.vietqr.io/image/970422-7900167896666-qr_only.png?amount=@Model.PhieuThu.TongThu&addInfo=" />
        </div>

        <div id="qr-td" style="display:none" class="col-sm-12">
            <p class="text-center" style="border-top:dashed 1px; font-size:10px;vertical-align:top">
                Chuyển khoản - CN Tam Điệp: 8827979888 - Tạ Thị Thanh Nga - BIDV CN Tam Diep PGD Yen Khanh
            </p>
            <img style="width: 190px; margin: auto;display:block"
                 src="https://img.vietqr.io/image/970418-8827979888-qr_only.png?amount=@Model.PhieuThu.TongThu&addInfo=" />
        </div>

        <p class="text-center" style="font-size:10px;vertical-align:top">
            <b>Vui lòng kiểm tra phiếu trước khi rời văn phòng!</b>
        </p>
    </div>

</body>
</html>