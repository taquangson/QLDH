
@{
    ViewBag.Title = "Bán phiếu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/js/phieuthu.js"></script>
<style>
    .trang {
        background-color: #fff;
    }

    .do {
        background-color: #fc9595;
    }

    .xanh {
        background-color: #78ff51;
    }

    .k-dialog-buttongroup .k-button {
        width: 50%;
    }
</style>
<div id="rootContainer" style="display:none">
    <div id="dialogRoot"></div>
    <div class="row">
        <h2><b>Quản lý bán phiếu vào lớp</b></h2>
    </div>
    <div class="row">
        <div id="gridTimKiemHocSinh"></div>
    </div>
</div>

<script type="text/x-kendo-template" id="template">
    <div class="orders"></div>
</script>

<div id="windowLapPhieuThu">
    <div class="toolBarMenu">
        <button class="k-button bg-green" onclick="TaoPhieuThu()"> <i class="fa fa-print"> In </i></button>
        <button class="k-button bg-blue" onclick="LuuTamTinh()"> <i class="fa fa-plus-square"> Lưu tạm tính</i></button>
        <button class="k-button bg-blue" onclick="ThongBaoHocPhi()"> <i class="fa fa-paper-plane"> Gửi thông báo học phí</i></button>
        <button class="k-button bg-red" onclick="HuyPhieuThu()"> <i class="fa fa-close"> Hủy </i> </button>
        <div style="float:right">
            <span style="color:#3e835a">Phiếu tạm tính: </span><div style="width:300px;" id="combotamtinh"></div>
        </div>
    </div>
    <div style="width:100%">
        <div style="width:63%;float:left;margin-left:2%">
            <h4 style="width:100%;text-align:center;text-transform:uppercase">PHIẾU THANH TOÁN</h4>
            <div>
                <input id="ID_HocSinh" type="hidden" />
                <input id="ID_PhieuThu" type="hidden" />
            </div>
            <div style="margin-top:10px">
                <div style="width:25%;float:left;margin-bottom:10px;">
                    <label style="width:100%">Học sinh:</label>
                    <input id="TenHocSinh" type="text" class="k-textbox" readonly="readonly" />
                </div>
                <div style="width:25%;float:left">
                    <label style="width:100%">Tổng tiền:</label>
                    <input id="TongTien" type="text" class="k-textbox" readonly="readonly" />
                </div>
                <div style="width:25%;float:left">
                    <label style="width:100%">Khách đưa:</label>
                    <input id="KhachDua" />
                </div>
                <div style="width:25%;float:left">
                    <label style="width:100%">Trả lại:</label>
                    <input id="TraLai" type="text" class="k-textbox" readonly="readonly" />
                </div>
            </div>
            <div style="margin-top:10px">
                <label style="width:100%">Danh sách phiếu mua:</label>
                <div id="gridPhieuMua"></div>
            </div>
            <div style="width:100%;margin-top:10px">
                <div style="width:50%;float:left">
                    <label style="width:100%">Phụ thu:</label>
                    <div id="gridPhuThu"></div>
                </div>
                <div style="width:50%;float:left">
                    <label style="width:100%">Giảm trừ:</label>
                    <div id="gridGiamTru"></div>
                </div>
            </div>
        </div>
        <div style="width:33%;float:left;margin-left:2%">
            <h4 style="width:100%;text-align:center;text-transform:uppercase">Thống kê tháng trước</h4>
            <div style="margin-top:67px">
                <label style="width:100%">Thống kê phiếu kể từ tháng trước:</label>
                <div id="gridPhieuThangTruoc"></div>
            </div>
            <div style="margin-top:10px">
                <label style="width:100%">Thống kê buổi học tháng trước:</label>
                <div id="gridBuoiHocThangTruoc"></div>
            </div>
        </div>
    </div>
</div>
<div id="windowLichSuPhieuThu">
    <div id="gridLichSuPhieuThu"></div>
</div>

<script id="rowTemplate" type="text/x-kendo-tmpl">
    <tr class='#= SoBuoiHoc == SoBuoiDaMua ? "trang" : SoBuoiHoc < SoBuoiDaMua ? "xanh" : "do"#'>
        <td>
            #= TenLop #
        </td>
        <td class="text-center">
            #= Thang # / #= Nam #
        </td>
        <td class="text-center">
            #= SoBuoiHoc # / #= SoBuoiDaMua #
        </td>
        <td class="text-center">
            #= SoBuoiTheoLich #
        </td>
    </tr>
</script>