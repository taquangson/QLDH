        function compareValues(key, order = 'asc') {
            return function innerSort(a, b) {
                if (!a.hasOwnProperty(key) || !b.hasOwnProperty(key)) {
                    // property doesn't exist on either object
                    return 0;
                }

                const varA = (typeof a[key] === 'string')
                    ? a[key].toUpperCase() : a[key];
                const varB = (typeof b[key] === 'string')
                    ? b[key].toUpperCase() : b[key];

                let comparison = 0;
                if (varA > varB) {
                    comparison = 1;
                } else if (varA < varB) {
                    comparison = -1;
                }
                return (
                    (order === 'desc') ? (comparison * -1) : comparison
                );
            };
        }


        function PushFormDataFile(file) {
            kendo.ui.progress($("body"), true);
            parseExcel(file.rawFile);
        }

        function ProcessData() {
            $("#grid").data("kendoGrid").options.excel = {
                fileName: selectedPhongBan.text + ".xlsx",
                filterable: true,
                allPages: true
            }
            $("#grid").data("kendoGrid").saveAsExcel();
        }


        function parseExcel(file) {
            var reader = new FileReader();

            reader.onload = function (e) {
                var data = e.target.result;
                var workbook = XLSX.read(data, {
                    type: 'binary'
                });

                workbook.SheetNames.forEach(function (sheetName) {
                    // Here is your object
                    var XL_row_object = XLSX.utils.sheet_to_row_object_array(workbook.Sheets[sheetName]);
                    var json_object = JSON.stringify(XL_row_object);

                    jsondata = JSON.parse(json_object);
                    $.each(jsondata, function (index, item) {
                        item.Market_cap = Number(item.Market_cap);
                        //item.Total_assets = Number(item.Total_assets);
                        //item.Total_liabilities = Number(item.Total_liabilities);
                        item.Debt_to_assets = Number(item.Debt_to_assets);
                        item.MB = Number(item.MB);
                    })

                    jsondata = jsondata.sort(compareValues('Debt_to_assets','desc'));
                    lenght = jsondata.length;
                    var dsgrid = new kendo.data.DataSource({
                        data: jsondata,
                        //pageSize: 50
                    });
                    $("#grid").data("kendoGrid").setDataSource(dsgrid);
                    kendo.ui.progress($("body"), false);
                    notification.show({ kValue: "Tải dữ liệu thành công" }, "success");
                })

            };

            reader.onerror = function (ex) {
                console.log(ex);
            };

            reader.readAsBinaryString(file);

        };
/**/</script>
