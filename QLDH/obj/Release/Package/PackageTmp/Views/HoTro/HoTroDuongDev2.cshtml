                    if ($("#file").data("kendoUpload").getFiles().length > 0) {
                        kendo.ui.progress($("body"), true);
                        selectedPhongBan = $("#treeview").getKendoTreeView().dataItem(e.node);
                        if (selectedPhongBan.value.toString().length == 2) {
                            var digits = ("" + selectedPhongBan.value).split("");
                            let T = lenght;
                            let A = digits[0];
                            let B = digits[1];
                            let P1 = Math.round(T * A / 3);
                            let P2 = Math.round(T * (A - 1) / 3);
                            let sortData = jsondata.slice(P2, P1).sort(compareValues('Market_cap'), 'desc');


                            let L1 = P1 - P2;
                            let C1 = Math.round(L1 * B / 2);
                            let C2 = Math.round(L1 * (B - 1) / 2);
                            let X1 = P2 + C2;
                            let X2 = P2 + C1;
                            sortData = sortData.slice(X1, X2).sort(compareValues('MB', 'desc'));
                            let L3 = C1 - C2;
                            let Y1 = Math.round(L3 * 0.3);
                            let Y2 = Math.round(L3 * 0.7);
                            let Y3 = Math.round(L3 * 1);
                            $.each(sortData, function (index, item) {
                                if (index < Y1) {
                                    item.Rank = "Growth";
                                }
                                if (Y1 <= index && index < Y2) {
                                    item.Rank = "Neutral";
                                }
                                if (Y2 <= index && index < Y3) {
                                    item.Rank = "Value";
                                }
                            })
                            var dsgrid = new kendo.data.DataSource({
                                data: sortData,
                                //pageSize: 50
                            });
                            $("#grid").data("kendoGrid").setDataSource(dsgrid);
                            kendo.ui.progress($("body"), false);
                        }
