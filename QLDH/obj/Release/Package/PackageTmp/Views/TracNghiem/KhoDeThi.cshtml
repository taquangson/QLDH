<script type="text/x-kendo-tmpl" id="templateeditbailam">
    <div class="valid">
        <textarea id="DapAn#:ID_CauHoi#" data-bind="value:TraLoi" name="TraLoi" style="width:100%;height:300px;" rows="2" class="k-textbox"></textarea>
    </div>
    <div class="valid">
        <label style="width:100%;;margin-top:7px;">Ảnh đáp án: </label>
        <input id="AnhDapAn#:ID_CauHoi#" type="file" />
    </div>
    <div class="edit-buttons text-center">
        <a class="k-button k-update-button" href="\\#"><span class="k-icon k-i-check"></span> Lưu lời phê</a>
        @*<a class="k-button k-cancel-button" href="\\#"><span class="k-icon k-i-cancel"></span> Hủy</a>*@
    </div>
</script>


<div id="templateCauHoiTooltip" style="display:none">
    <div style="width:100%;padding-top:10px;">
        <b>#= htmlDecode(NoiDungCauHoi)#</b>
        # $.each(lstDapAn, function(index, item){#
        <div style="width:46%;float:left;padding:1%; # if(item.IsDapAnDung){ # color:green #}# ">
            #: Ans[index] #. #: item.DapAn == null ? "" : item.DapAn #
            #if(item.AnhDapAn != null){#
            <img src="../Images/AnhDapAn/#:item.AnhDapAn #" style="max-width:150px;" />
            #}#
        </div>
        #})#
    </div>
</div>

<div id="windowGiaoDeThi">
    <input type="hidden" id="ID_De" />
    <div style="width:60%;float:left">
        <div id="gridHocSinhDaGiao"></div>
    </div>
    <div style="width:40%;float:left">
        <div id="gridHocSinh"></div>
    </div>
</div>