@{
    ViewBag.Title = "Thống kê buổi học theo giáo viên";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/js/baocao_js/thongkebuoihoctheogiaovien.js"></script>
<style>
    .k-scheduler-monthview .k-scheduler-table td {
        height: 130px !important;
    }

    .k-other-month {
        color: #ffffff;
        background-color: #2a3f54;
    }

    .k-event {
        height: 15px !important;
        min-height:10px !important;
    }
</style>
<div id="rootContainer" style="display:none">
    <div class="row">
        <h2><b>Thống kê buổi học theo giáo viên</b></h2>
    </div>
    <div class="row">
        <div class="col-sm-3">
            <label style="width:100%">Tên giáo viên</label>
            <div style="width:100%" id="comboGiaoVien"></div>
        </div>
        <div class="col-sm-3">
            <label style="width:100%">Khối</label>
            <div style="width:100%" id="comboKhoi"></div>
        </div>
        <div class="col-sm-3">
            <label style="width:100%">Lớp</label>
            <div style="width:100%" id="comboLop"></div>
        </div>
    </div>
    <div class="row" style="margin-top:10px;">
        <div class="col-sm-3">
            <label style="width:100%">Từ ngày</label>
            <input style="width:100%" id="TuNgay" />
        </div>
        <div class="col-sm-3">
            <label style="width:100%">Đến ngày</label>
            <input style="width:100%" id="DenNgay" />
        </div>
        <div class="col-sm-3">
            <label style="width:100%"> </label>
            <button class="k-button bg-blue" onclick="TimKiem()"> <i class="fa fa-search"> Xem báo cáo </i></button>
            <button class="k-button bg-green" onclick="XuatExcel()"> <i class="fa fa-file-excel-o"> Xuất excel </i></button>
        </div>
    </div>
    <div id="tabstrip" style="margin-top:10px;">
        <ul>
            <li class="k-state-active">
                Lịch sử giảng dạy
            </li>
            <li>
                Thống kê chi tiết
            </li>
        </ul>
        <div style="border:none;padding:0px;margin:0px;">
            <div id="scheduler"></div>
        </div>
        <div style="border:none;padding:0px;margin:0px;">
            <div id="gridthongkebuoihoctheogiaovien"></div>
        </div>
    </div>
</div>

<script id="eventschedule_template" type="text/x-kendo-template">
    <div style="float:left;height:15px;font-size:11px;width:35%;text-align:left;line-height:15px">
        #= SiSo #
    </div>
    <div style="float:left;height:15px;font-size:11px;width:55%;text-align:right;line-height:15px">
        #= title #
    </div>
</script>