@using QLDH.DataAccess.Models;
@{
    ViewBag.Title = "Quản lý lớp";
    Layout = "~/Views/Shared/_Layout2.cshtml";

}
<style>
    #videos {
        display: flex;
        flex-wrap: wrap;
        margin-top: 20px;
    }

        #videos .vd {
            flex: 1 1 50%;
            padding: 0;
            min-width: 0;
            max-width: 33%;
            min-height:100px;
        }

    video {
        width: 100%;
        max-height: 140px;
        background-color: #111;
    }
</style>
<script src="~/Assets/stringeeConfig.js"></script>
<script>
    var roomId = '@ViewBag.RoomID';
    var userId = '@ViewBag.ID_User';
</script>
<script src="~/Scripts/js/room.js"></script>
<script src="https://cdn.stringee.com/sdk/web/2.2.1/stringee-web-sdk.min.js"></script>

<div class="row text-center">
    <h4><b>Tên lớp: @ViewBag.TenLop</b></h4>
</div>
<b>Giáo viên: @ViewBag.TenGiaoVien</b>
<div id="videos-@ViewBag.ID_GiaoVien">
</div>
<div id="videos">

    @for (int i = 0; i < ((List<HocSinhModel>)ViewBag.ListHocSinh).Count; i++)
    {
        <div class="vd text-center" id="videos-@ViewBag.ListHocSinh[i].ID">
            <b>@ViewBag.ListHocSinh[i].TenHocSinh</b>
        </div>
    }

</div>